        "#soru51\n",
        "import re\n",
        "\n",
        "def sifre_gucluluk_kontrolu(sifre_input):\n",
        "    uzunluk_kriteri = len(sifre_input) >= 8\n",
        "    kucuk_harf_kriteri = re.search(r'[a-z]', sifre_input)\n",
        "    buyuk_harf_kriteri = re.search(r'[A-Z]', sifre_input)\n",
        "    rakam_kriteri = re.search(r'[0-9]', sifre_input)\n",
        "    ozel_karakter_kriteri = re.search(r'[^a-zA-Z0-9]', sifre_input)\n",
        "\n",
        "    puan = 0\n",
        "    if uzunluk_kriteri: puan += 1\n",
        "    if kucuk_harf_kriteri: puan += 1\n",
        "    if buyuk_harf_kriteri: puan += 1\n",
        "    if rakam_kriteri: puan += 1\n",
        "    if ozel_karakter_kriteri: puan += 1\n",
        "\n",
        "    if puan == 5:\n",
        "        return \"Güçlü\"\n",
        "    elif puan >= 3:\n",
        "        return \"Orta\"\n",
        "    else:\n",
        "        return \"Zayıf\"\n",
        "\n",
        "sifre_girisi = input(\"Lütfen bir şifre girin: \")\n",
        "gucluluk = sifre_gucluluk_kontrolu(sifre_girisi)\n",
        "print(f\"Şifre gücü: {gucluluk}\")"
      ],
